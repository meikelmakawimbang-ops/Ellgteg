{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild plugins/*.ts --platform=node --format=esm --outdir=dist/plugins && mkdir -p dist/lib && cp -r lib/* dist/lib/ && cp config.js handler.js dist/",
    "start": "NODE_ENV=production node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hapi/boom": "^10.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@whiskeysockets/baileys": "^7.0.0-rc11",
    "axios": "^1.16.0",
    "buffer": "^6.0.3",
    "canvas": "^3.2.3",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "events": "^3.3.0",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "lucide-react": "^0.546.0",
    "moment-timezone": "^0.6.2",
    "mongoose": "^9.6.2",
    "motion": "^12.23.24",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.3",
    "wa-sticker-formatter": "^4.4.4",
    "yt-search": "^2.13.1",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
